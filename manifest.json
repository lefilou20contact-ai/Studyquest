{
  "background_color": "#0f0f1a",
  "dir": "ltr",
  "display": "standalone",
  "display_override": ["window-controls-overlay", "standalone", "browser"],
  "name": "StudyQuest",
  "short_name": "StudyQuest",
  "description": "Mon app de révision personnalisée — Maths, Français, Histoire, Sciences et plus !",
  "lang": "fr",
  "orientation": "any",
  "scope": "https://lefilou20contact-ai.github.io/Studyquest/",
  "start_url": "https://lefilou20contact-ai.github.io/Studyquest/",
  "theme_color": "#e94560",
  "id": "studyquest",
  "categories": ["education"],
  "prefer_related_applications": false,

  "icons": [
    { "src": "launchericon-48x48.png", "sizes": "48x48", "type": "image/png", "purpose": "any" },
    { "src": "launchericon-72x72.png", "sizes": "72x72", "type": "image/png", "purpose": "any" },
    { "src": "launchericon-96x96.png", "sizes": "96x96", "type": "image/png", "purpose": "any" },
    { "src": "launchericon-144x144.png", "sizes": "144x144", "type": "image/png", "purpose": "any" },
    { "src": "launchericon-192x192.png", "sizes": "192x192", "type": "image/png", "purpose": "any maskable" },
    { "src": "launchericon-512x512.png", "sizes": "512x512", "type": "image/png", "purpose": "any maskable" }
  ],

  "shortcuts": [
    {
      "name": "Quiz rapide",
      "short_name": "Quiz",
      "description": "Lance un quiz rapide",
      "url": "https://lefilou20contact-ai.github.io/Studyquest/?action=quiz",
      "icons": [{ "src": "launchericon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Fiches de révision",
      "short_name": "Fiches",
      "description": "Révise avec des fiches",
      "url": "https://lefilou20contact-ai.github.io/Studyquest/?action=flashcards",
      "icons": [{ "src": "launchericon-96x96.png", "sizes": "96x96" }]
    },
    {
      "name": "Scanner mon cours",
      "short_name": "Scanner",
      "description": "Scanne un cours pour générer des exercices",
      "url": "https://lefilou20contact-ai.github.io/Studyquest/?action=scan",
      "icons": [{ "src": "launchericon-96x96.png", "sizes": "96x96" }]
    }
  ],

  "share_target": {
    "action": "https://lefilou20contact-ai.github.io/Studyquest/",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url"
    }
  },

  "file_handlers": [
    {
      "action": "https://lefilou20contact-ai.github.io/Studyquest/",
      "accept": {
        "text/plain": [".txt"],
        "image/png": [".png"],
        "image/jpeg": [".jpg", ".jpeg"]
      }
    }
  ],

  "launch_handler": {
    "client_mode": ["focus-existing", "auto"]
  },

  "protocol_handlers": [
    {
      "protocol": "web+studyquest",
      "url": "https://lefilou20contact-ai.github.io/Studyquest/?protocol=%s"
    }
  ],

  "edge_side_panel": {
    "preferred_width": 400
  },

  "widgets": [
    {
      "name": "StudyQuest Widget",
      "short_name": "StudyQuest",
      "description": "Révise rapidement avec StudyQuest",
      "tag": "studyquest-widget",
      "type": "application/json",
      "icons": [{ "src": "launchericon-192x192.png", "sizes": "192x192" }]
    }
  ],

  "note_taking": {
    "new_note_url": "https://lefilou20contact-ai.github.io/Studyquest/?action=scan"
  },

  "tab_strip": {
    "home_tab": {
      "url": "https://lefilou20contact-ai.github.io/Studyquest/"
    }
  },

  "screenshots": [
    {
      "src": "launchericon-512x512.png",
      "sizes": "512x512",
      "type": "image/png",
      "form_factor": "narrow",
      "label": "StudyQuest — Accueil"
    }
  ]
}
