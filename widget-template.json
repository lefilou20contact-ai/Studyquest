{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "📚 StudyQuest",
      "weight": "Bolder",
      "size": "Medium",
      "color": "Accent"
    },
    {
      "type": "TextBlock",
      "text": "${message}",
      "wrap": true,
      "size": "Small"
    },
    {
      "type": "TextBlock",
      "text": "⭐ XP: ${xp} | 🔥 Série: ${streak}",
      "size": "Small",
      "color": "Good"
    }
  ],
  "actions": [
    {
      "type": "Action.OpenUrl",
      "title": "🚀 Réviser",
      "url": "https://lefilou20contact-ai.github.io/Studyquest/"
    }
  ]
}
