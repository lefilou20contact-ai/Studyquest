{
  "$schema": "http://adaptivecards.io/schemas/adaptive-card.json",
  "type": "AdaptiveCard",
  "version": "1.5",
  "body": [
    {
      "type": "TextBlock",
      "text": "📚 StudyQuest",
      "weight": "Bolder",
      "size": "Medium",
      "color": "Accent",
      "horizontalAlignment": "Center"
    },
    {
      "type": "TextBlock",
      "text": "${message}",
      "wrap": true,
      "size": "Small",
      "horizontalAlignment": "Center"
    },
    {
      "type": "TextBlock",
      "text": "⭐ XP : ${xp}  |  🔥 Série : ${streak}  |  🎓 Niv. ${level}",
      "size": "Small",
      "color": "Good",
      "horizontalAlignment": "Center",
      "spacing": "Small"
    }
  ],
  "actions": [
    {
      "type": "Action.Execute",
      "title": "🚀 Réviser",
      "verb": "open-app"
    },
    {
      "type": "Action.Execute",
      "title": "⚡ Quiz",
      "verb": "open-quiz"
    },
    {
      "type": "Action.Execute",
      "title": "📸 Scanner",
      "verb": "open-scan"
    }
  ]
}
